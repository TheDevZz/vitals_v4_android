<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FaceActivity">

    <FrameLayout
        android:id="@+id/faceLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="9:16"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_gravity="center"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <TextView
        android:id="@+id/tips"
        android:fitsSystemWindows="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAlignment="center"
        android:gravity="center"
        android:textSize="20dp"
        android:textStyle="bold"
        android:text="健康一拍即知"
        android:textColor="@color/black"
        app:layout_constraintBottom_toTopOf="@+id/faceLayout"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0" />

    <TextView
        android:id="@+id/countdownText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/accent"
        android:textStyle="bold"
        android:textSize="16dp"
        android:visibility="invisible"
        tools:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/faceLayout"
        tools:text="剩余20s" />

    <ProgressBar
        android:id="@+id/progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="200dp"
        android:layout_height="8dp"
        android:layout_marginTop="8dp"
        android:progressDrawable="@drawable/progress"
        android:visibility="invisible"
        tools:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/countdownText"
        tools:progress="50" />

    <LinearLayout
        android:id="@+id/linearLayout2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/progress">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="环境质量" />

        <ImageView
            android:id="@+id/star1"
            android:layout_width="21dp"
            android:layout_height="20dp"
            android:layout_marginLeft="5dp"
            android:src="@drawable/star_activate" />

        <ImageView
            android:id="@+id/star2"
            android:layout_width="21dp"
            android:layout_height="20dp"
            android:layout_marginLeft="5dp"
            android:src="@drawable/star_activate" />

        <ImageView
            android:id="@+id/star3"
            android:layout_width="21dp"
            android:layout_height="20dp"
            android:layout_marginLeft="5dp"
            android:src="@drawable/star_activate" />

        <ImageView
            android:id="@+id/star4"
            android:layout_width="21dp"
            android:layout_height="20dp"
            android:layout_marginLeft="5dp"
            android:src="@drawable/star_activate" />

        <ImageView
            android:id="@+id/star5"
            android:layout_width="21dp"
            android:layout_height="20dp"
            android:layout_marginLeft="5dp"
            android:src="@drawable/star_activate" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/thresholdSeekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="72dp" />

    <TextView
        android:id="@+id/thresholdText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAlignment="center"
        app:layout_constraintBottom_toTopOf="@+id/thresholdSeekBar" />

</androidx.constraintlayout.widget.ConstraintLayout>